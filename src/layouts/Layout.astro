---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const { title, description = "ShopVirge — Launch your multilingual online shop or portfolio in minutes.", lang = "nl" } = Astro.props;
const base = import.meta.env.BASE_URL;
const isEn = lang === 'en';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | ShopVirge</title>
  <link rel="icon" type="image/png" href={`${base}images/logo.png`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="alternate" hreflang="nl" href="https://shopvirge.com/" />
  <link rel="alternate" hreflang="en" href="https://shopvirge.com/en/" />
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header -->
  <header class="fixed top-0 w-full bg-white/95 backdrop-blur-sm shadow-sm z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href={isEn ? `${base}en/` : base} class="flex items-center gap-2">
          <img src={`${base}images/logo.png`} alt="ShopVirge" class="h-9" />
        </a>
        
        <nav class="hidden md:flex items-center gap-8">
          <a href={isEn ? `${base}en/#features` : `${base}#features`} class="text-sm font-medium text-gray-700 hover:text-brand transition-colors">
            {isEn ? 'Features' : 'Functies'}
          </a>
          <a href={isEn ? `${base}en/#pricing` : `${base}#pricing`} class="text-sm font-medium text-gray-700 hover:text-brand transition-colors">
            {isEn ? 'Pricing' : 'Prijzen'}
          </a>
          <a href={isEn ? `${base}en/#contact` : `${base}#contact`} class="text-sm font-medium text-gray-700 hover:text-brand transition-colors">
            Contact
          </a>
          <a href={isEn ? base : `${base}en/`} class="text-sm font-medium text-gray-500 hover:text-brand transition-colors">
            {isEn ? '🇳🇱 NL' : '🇬🇧 EN'}
          </a>
          <a href={isEn ? `${base}en/#contact` : `${base}#contact`} class="btn-primary text-sm !px-5 !py-2">
            {isEn ? 'Get Started' : 'Start nu'}
          </a>
        </nav>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-700" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
    
    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden" style="display:none;">
      <div class="px-4 py-4 space-y-3 bg-white border-t">
        <a href={isEn ? `${base}en/#features` : `${base}#features`} class="block text-sm font-medium text-gray-700">{isEn ? 'Features' : 'Functies'}</a>
        <a href={isEn ? `${base}en/#pricing` : `${base}#pricing`} class="block text-sm font-medium text-gray-700">{isEn ? 'Pricing' : 'Prijzen'}</a>
        <a href={isEn ? `${base}en/#contact` : `${base}#contact`} class="block text-sm font-medium text-gray-700">Contact</a>
        <a href={isEn ? base : `${base}en/`} class="block text-sm font-medium text-gray-500">{isEn ? '🇳🇱 Nederlands' : '🇬🇧 English'}</a>
      </div>
    </div>
  </header>

  <main class="flex-1 pt-16">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-surface-dark text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <img src={`${base}images/logo.png`} alt="ShopVirge" class="h-8 mb-4 brightness-200" />
          <p class="text-gray-400 text-sm">
            {isEn 
              ? 'Launch your multilingual online shop or portfolio in minutes.' 
              : 'Lanceer je meertalige webshop of portfolio in enkele minuten.'}
          </p>
        </div>
        <div>
          <h4 class="font-semibold mb-3">{isEn ? 'Quick Links' : 'Snelle links'}</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href={isEn ? `${base}en/#features` : `${base}#features`} class="hover:text-white transition-colors">{isEn ? 'Features' : 'Functies'}</a></li>
            <li><a href={isEn ? `${base}en/#pricing` : `${base}#pricing`} class="hover:text-white transition-colors">{isEn ? 'Pricing' : 'Prijzen'}</a></li>
            <li><a href={isEn ? `${base}en/#contact` : `${base}#contact`} class="hover:text-white transition-colors">Contact</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-3">{isEn ? 'Visit us' : 'Bezoek ons'}</h4>
          <address class="text-sm text-gray-400 not-italic">
            Julianastraat 63<br />
            6039 AH Stramproy<br />
            {isEn ? 'The Netherlands' : 'Nederland'}
          </address>
        </div>
      </div>
      <div class="border-t border-gray-700 mt-8 pt-8 text-center text-sm text-gray-500">
        &copy; {new Date().getFullYear()} ShopVirge. All rights reserved.
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu!.style.display = menu!.style.display === 'none' ? 'block' : 'none';
    });
  </script>
</body>
</html>
