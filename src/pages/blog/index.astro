---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const postFiles = import.meta.glob('./*.md', { eager: true });
const posts = Object.values(postFiles) as any[];
const sortedPosts = posts.sort((a, b) => 
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---
<Layout title="Blog" description="E-commerce insights, trends en tips voor ondernemers." lang="nl">
  <!-- Hero -->
  <section class="hero py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Blog</h1>
        <p class="text-xl text-white/80">
          E-commerce trends, tips en inzichten voor ondernemers die online willen groeien.
        </p>
      </div>
    </div>
  </section>

  <!-- Posts -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map((post) => (
          <a href={post.url} class="group block bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all">
            {post.frontmatter.image && (
              <div class="aspect-video overflow-hidden">
                <img 
                  src={post.frontmatter.image.startsWith('http') ? post.frontmatter.image : `${base}${post.frontmatter.image}`}
                  alt={post.frontmatter.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
              </div>
            )}
            <div class="p-6">
              <div class="flex items-center gap-3 text-sm text-text-light mb-3">
                <time datetime={post.frontmatter.date}>
                  {new Date(post.frontmatter.date).toLocaleDateString('nl-NL', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                {post.frontmatter.author && (
                  <>
                    <span>•</span>
                    <span>{post.frontmatter.author}</span>
                  </>
                )}
              </div>
              {post.frontmatter.tags && (
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {post.frontmatter.tags.slice(0, 2).map((tag: string) => (
                    <span class="inline-block px-2 py-0.5 bg-brand/10 text-brand text-xs font-semibold rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
              <h2 class="text-lg font-bold text-text-heading mb-2 group-hover:text-brand transition-colors line-clamp-2">
                {post.frontmatter.title}
              </h2>
              <p class="text-text-light text-sm line-clamp-3">
                {post.frontmatter.description}
              </p>
              <span class="inline-block mt-4 text-brand font-semibold text-sm">
                Lees meer →
              </span>
            </div>
          </a>
        ))}
      </div>

      {sortedPosts.length === 0 && (
        <div class="text-center py-12">
          <p class="text-text-light">Nog geen blogposts. Kom snel terug!</p>
        </div>
      )}
    </div>
  </section>
</Layout>
