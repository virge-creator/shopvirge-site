---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="ShopVirge — Multilingual webshops & portfolios" lang="en">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Hero image -->
    <div class="relative w-full h-[500px] md:h-[600px] lg:h-[700px]">
      <img 
        src={`${base}images/hero-home.jpg`}
        alt="ShopVirge — Automatically translate your webshop to any language"
        class="w-full h-full object-cover"
      />
      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/90 via-brand/70 to-transparent"></div>
      <!-- Content overlay -->
      <div class="absolute inset-0 flex items-center">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
          <div class="max-w-2xl">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight text-white drop-shadow-lg">
              Your webshop, <span class="text-amber-400">in any language</span>, in minutes.
            </h1>
            <p class="text-lg md:text-xl text-white/90 mb-8 drop-shadow">
              ShopVirge builds your multilingual webshop or portfolio — no code, no hassle. 
              Describe your products once, and we'll handle the rest.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href={`${base}en/contact/`} class="btn-primary bg-white text-brand hover:bg-gray-100 shadow-lg">
                Start free →
              </a>
              <a href={`${base}nl/portfolio`} class="btn-secondary border-white text-white hover:bg-white/20 shadow-lg">
                See examples
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features teaser -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Everything you need to grow</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">From automatic translations to payment integrations — ShopVirge handles it.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="globe" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Automatic multilingual</h3>
          <p class="text-gray-600">Your entire site gets translated automatically. You choose which languages.</p>
        </div>
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="zap" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Live in under an hour</h3>
          <p class="text-gray-600">From concept to live site in less than an hour. No technical knowledge needed.</p>
        </div>
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="credit-card" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Payment platforms built-in</h3>
          <p class="text-gray-600">iDEAL, PayPal, credit card — all integrated, no plugins.</p>
        </div>
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="smartphone" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Mobile-first design</h3>
          <p class="text-gray-600">Perfect on phone, tablet and desktop. Optimized for conversion.</p>
        </div>
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="palette" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">No design skills needed</h3>
          <p class="text-gray-600">Professional-looking websites out of the box with ready-made templates.</p>
        </div>
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="bar-chart-3" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Analytics built-in</h3>
          <p class="text-gray-600">Track visitors, conversions and product performance. No external tools.</p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href={`${base}en/features/`} class="btn-primary">View all features →</a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section-alt py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">How it works</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-brand text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
          <h3 class="text-xl font-bold mb-2">Tell us what you sell</h3>
          <p class="text-gray-600">Describe your products or services. Upload photos. Give us the basics.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-brand text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
          <h3 class="text-xl font-bold mb-2">We translate everything</h3>
          <p class="text-gray-600">Choose your languages and ShopVirge automatically translates your entire site.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-brand text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
          <h3 class="text-xl font-bold mb-2">Go live</h3>
          <p class="text-gray-600">Publish with one click. From that moment on, your multilingual shop runs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing teaser -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Simple pricing</h2>
        <p class="text-lg text-gray-600">No surprises. Pay for what you use.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="card border-2 border-brand">
          <div class="text-center mb-4">
            <span class="inline-block px-3 py-1 bg-brand/10 text-brand text-sm font-semibold rounded-full mb-3">Popular</span>
            <h3 class="text-2xl font-bold">Webshop</h3>
            <p class="text-gray-600 mt-2">Sell products online in multiple languages</p>
          </div>
          <ul class="space-y-2 mb-6 text-sm">
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> Unlimited products</li>
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> Automatic translation</li>
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> iDEAL, PayPal, credit card</li>
          </ul>
          <a href={`${base}en/pricing/`} class="btn-primary w-full text-center block">More info →</a>
        </div>
        <div class="card">
          <div class="text-center mb-4">
            <h3 class="text-2xl font-bold mt-8">Portfolio</h3>
            <p class="text-gray-600 mt-2">Showcase your work to the world</p>
          </div>
          <ul class="space-y-2 mb-6 text-sm">
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> Unlimited projects</li>
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> Automatic translation</li>
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> SEO optimized</li>
          </ul>
          <a href={`${base}en/pricing/`} class="btn-secondary w-full text-center block">More info →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-alt py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to get started?</h2>
      <p class="text-gray-600 mb-8">Get in touch and we'll help you within 24 hours.</p>
      <a href={`${base}en/contact/`} class="btn-primary">Contact us →</a>
    </div>
  </section>
</Layout>
