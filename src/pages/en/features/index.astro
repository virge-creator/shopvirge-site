---
import Layout from '../../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Features — Everything you need" lang="en">
  <section class="hero text-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Features</h1>
        <p class="text-xl text-white/80">
          Everything you need to launch a professional, multilingual webshop or portfolio.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-24">

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-5xl mb-4">🌍</div>
          <h2 class="text-3xl font-bold mb-4">Automatic multilingual</h2>
          <p class="text-gray-600 mb-4">Your entire site — products, text, pages — gets translated automatically in the languages you choose.</p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Dutch, English, German, French, Spanish and more</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> SEO-optimized translations per language</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Manual adjustments always possible</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Automatic language detection for visitors</li>
          </ul>
        </div>
        <div class="bg-brand/5 rounded-2xl p-12 flex items-center justify-center"><div class="text-8xl">🌐</div></div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="md:order-2">
          <div class="text-5xl mb-4">⚡</div>
          <h2 class="text-3xl font-bold mb-4">Live in under an hour</h2>
          <p class="text-gray-600 mb-4">From concept to fully live site in less than an hour. No technical knowledge needed.</p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Step-by-step guidance</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Drag-and-drop product uploads</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Automatic sitemap and SEO</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Publish with one click</li>
          </ul>
        </div>
        <div class="bg-accent/10 rounded-2xl p-12 flex items-center justify-center md:order-1"><div class="text-8xl">🚀</div></div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-5xl mb-4">💳</div>
          <h2 class="text-3xl font-bold mb-4">Payment platforms built-in</h2>
          <p class="text-gray-600 mb-4">Accept payments via iDEAL, PayPal, credit card and more — all integrated, no plugins.</p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> iDEAL, Bancontact, PayPal</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Credit card (Visa, Mastercard, Amex)</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Klarna and buy-now-pay-later</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Automatic invoices and receipts</li>
          </ul>
        </div>
        <div class="bg-brand/5 rounded-2xl p-12 flex items-center justify-center"><div class="text-8xl">💰</div></div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="md:order-2">
          <div class="text-5xl mb-4">📱</div>
          <h2 class="text-3xl font-bold mb-4">Mobile-first design</h2>
          <p class="text-gray-600 mb-4">Every site looks perfect on phone, tablet and desktop. Optimized for speed and conversion.</p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Responsive on every screen size</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Super fast (&lt; 1s load time)</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Touch-optimized navigation</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> PWA-ready</li>
          </ul>
        </div>
        <div class="bg-accent/10 rounded-2xl p-12 flex items-center justify-center md:order-1"><div class="text-8xl">📲</div></div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-5xl mb-4">🎨</div>
          <h2 class="text-3xl font-bold mb-4">No design skills needed</h2>
          <p class="text-gray-600 mb-4">Professional-looking websites out of the box. Choose from templates and customize with your brand.</p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> 20+ professional templates</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Custom colors, fonts and logo</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Custom CSS possible</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Dark mode support</li>
          </ul>
        </div>
        <div class="bg-brand/5 rounded-2xl p-12 flex items-center justify-center"><div class="text-8xl">🎭</div></div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="md:order-2">
          <div class="text-5xl mb-4">📊</div>
          <h2 class="text-3xl font-bold mb-4">Analytics built-in</h2>
          <p class="text-gray-600 mb-4">Track visitors, conversions and product performance with built-in dashboards.</p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Real-time visitor statistics</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Conversion tracking</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Bestseller and trend reports</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> GDPR-compliant (no cookies)</li>
          </ul>
        </div>
        <div class="bg-accent/10 rounded-2xl p-12 flex items-center justify-center md:order-1"><div class="text-8xl">📈</div></div>
      </div>

    </div>
  </section>

  <section class="section-alt py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to get started?</h2>
      <p class="text-gray-600 mb-8">Launch your multilingual webshop or portfolio today.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}en/contact/`} class="btn-primary">Get in touch →</a>
        <a href={`${base}en/pricing/`} class="btn-secondary">View pricing</a>
      </div>
    </div>
  </section>
</Layout>
