---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Prijzen — Eenvoudig en transparant" lang="nl">
  <section class="hero text-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Prijzen</h1>
        <p class="text-xl text-white/80">
          Geen verrassingen. Transparante prijzen voor elk type project.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing cards -->
  <section class="py-20 md:py-28">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8">
        
        <!-- Webshop -->
        <div class="card border-2 border-brand relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2">
            <span class="inline-block px-4 py-1.5 bg-brand text-white text-sm font-semibold rounded-full">Populair</span>
          </div>
          <div class="text-center pt-4 mb-8">
            <h3 class="text-2xl font-bold mb-2">Webshop</h3>
            <p class="text-gray-600">Verkoop producten online in meerdere talen</p>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Onbeperkte producten</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Automatisch vertalen (NL/EN + meer)</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> iDEAL, PayPal, creditcard</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Mobiel-first design</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Analytics dashboard</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> SEO geoptimaliseerd</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> SSL-certificaat inbegrepen</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Eigen domein</li>
          </ul>
          <a href={`${base}contact/`} class="btn-primary w-full text-center block">Start nu →</a>
        </div>

        <!-- Portfolio -->
        <div class="card">
          <div class="text-center mb-8 pt-4">
            <h3 class="text-2xl font-bold mb-2">Portfolio</h3>
            <p class="text-gray-600">Toon je werk aan de wereld</p>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Onbeperkte projecten</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Automatisch vertalen (NL/EN + meer)</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Contactformulier</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Mobiel-first design</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> SEO geoptimaliseerd</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> SSL-certificaat inbegrepen</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Eigen domein</li>
            <li class="flex items-center gap-2 text-sm"><span class="text-brand">✓</span> Gallerij met lightbox</li>
          </ul>
          <a href={`${base}contact/`} class="btn-secondary w-full text-center block">Vraag offerte aan →</a>
        </div>
      </div>

      <!-- FAQ -->
      <div class="mt-20">
        <h2 class="text-3xl font-bold text-center mb-12">Veelgestelde vragen</h2>
        <div class="space-y-6 max-w-3xl mx-auto">
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-lg mb-2">Zijn er opstartkosten?</h3>
            <p class="text-gray-600">Nee, je betaalt alleen het maandelijkse abonnement. Geen verborgen kosten.</p>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-lg mb-2">Kan ik op elk moment opzeggen?</h3>
            <p class="text-gray-600">Ja, je zit nergens aan vast. Maandelijks opzegbaar.</p>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-lg mb-2">Hoeveel talen kan ik toevoegen?</h3>
            <p class="text-gray-600">Standaard NL/EN. Extra talen (DE, FR, ES, etc.) kunnen worden toegevoegd op aanvraag.</p>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-lg mb-2">Krijg ik hulp bij het opzetten?</h3>
            <p class="text-gray-600">Absoluut. We begeleiden je stap voor stap bij de lancering van je site.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-alt py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold mb-4">Niet zeker welk pakket bij je past?</h2>
      <p class="text-gray-600 mb-6">Neem contact op en we helpen je de juiste keuze maken.</p>
      <a href={`${base}contact/`} class="btn-primary">Neem contact op →</a>
    </div>
  </section>
</Layout>
