---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="ShopVirge — Meertalige webshops & portfolios" lang="nl">
  <!-- Hero -->
  <section class="hero text-white py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight">
          Je webshop, <span class="text-accent">in elke taal</span>, in enkele minuten.
        </h1>
        <p class="text-xl md:text-2xl text-white/80 mb-8">
          ShopVirge bouwt je meertalige webshop of portfolio — geen code, geen gedoe. 
          Beschrijf je producten één keer, en wij zorgen voor de rest.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={`${base}nl/contact/`} class="btn-primary bg-white text-brand hover:bg-gray-100">
            Start gratis →
          </a>
          <a href={`${base}nl/portfolio`} class="btn-secondary border-white text-white hover:bg-white hover:text-brand">
            Bekijk voorbeelden
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features teaser -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Alles wat je nodig hebt om te groeien
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Van automatische vertalingen tot betaalde integraties — ShopVirge handelt het af.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="globe" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Automatisch meertalig</h3>
          <p class="text-gray-600">Jouw hele site wordt automatisch vertaald. Kies zelf welke talen.</p>
        </div>
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="zap" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Live in één uur</h3>
          <p class="text-gray-600">Van concept tot live site in minder dan een uur. Geen technische kennis nodig.</p>
        </div>
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="credit-card" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Betaalplatforms ingebakken</h3>
          <p class="text-gray-600">iDEAL, PayPal, creditcard — allemaal geïntegreerd, zonder extra plugins.</p>
        </div>
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="smartphone" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Mobiel-first design</h3>
          <p class="text-gray-600">Perfect op telefoon, tablet en desktop. Geoptimaliseerd voor conversie.</p>
        </div>
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="palette" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Geen design-skills nodig</h3>
          <p class="text-gray-600">Professioneel ogende websites uit de doos met kant-en-klare templates.</p>
        </div>
        <div class="card">
          <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="bar-chart-3" size={24} class="text-brand" />
          </div>
          <h3 class="text-xl font-bold mb-2">Analytics ingebouwd</h3>
          <p class="text-gray-600">Volg bezoekers, conversies en productprestaties. Geen externe tools nodig.</p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href={`${base}nl/functies/`} class="btn-primary">Bekijk alle functies →</a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section-alt py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Hoe het werkt</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-brand text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
          <h3 class="text-xl font-bold mb-2">Vertel wat je verkoopt</h3>
          <p class="text-gray-600">Beschrijf je producten of diensten. Upload foto's. Geef de basis mee.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-brand text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
          <h3 class="text-xl font-bold mb-2">Wij vertalen alles</h3>
          <p class="text-gray-600">Kies je talen en ShopVirge vertaalt je hele site automatisch.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-brand text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
          <h3 class="text-xl font-bold mb-2">Ga live</h3>
          <p class="text-gray-600">Publish met één klik. Vanaf dat moment draait je meertalige shop.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing teaser -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Eenvoudige prijzen</h2>
        <p class="text-lg text-gray-600">Geen verrassingen. Betaal voor wat je gebruikt.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="card border-2 border-brand">
          <div class="text-center mb-4">
            <span class="inline-block px-3 py-1 bg-brand/10 text-brand text-sm font-semibold rounded-full mb-3">Populair</span>
            <h3 class="text-2xl font-bold">Webshop</h3>
            <p class="text-gray-600 mt-2">Verkoop producten online in meerdere talen</p>
          </div>
          <ul class="space-y-2 mb-6 text-sm">
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> Onbeperkte producten</li>
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> Automatisch vertalen</li>
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> iDEAL, PayPal, creditcard</li>
          </ul>
          <a href={`${base}nl/prijzen/`} class="btn-primary w-full text-center block">Meer info →</a>
        </div>
        <div class="card">
          <div class="text-center mb-4">
            <h3 class="text-2xl font-bold mt-8">Portfolio</h3>
            <p class="text-gray-600 mt-2">Toon je werk aan de wereld</p>
          </div>
          <ul class="space-y-2 mb-6 text-sm">
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> Onbeperkte projecten</li>
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> Automatisch vertalen</li>
            <li class="flex items-center gap-2"><span class="text-brand">✓</span> SEO geoptimaliseerd</li>
          </ul>
          <a href={`${base}nl/prijzen/`} class="btn-secondary w-full text-center block">Meer info →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-alt py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Klaar om te starten?</h2>
      <p class="text-gray-600 mb-8">Neem contact op en we helpen je binnen 24 uur verder.</p>
      <a href={`${base}nl/contact/`} class="btn-primary">Neem contact op →</a>
    </div>
  </section>
</Layout>
