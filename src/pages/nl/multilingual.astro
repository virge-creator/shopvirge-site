---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Meertalige webshops — ShopVirge" description="Bouw een webshop die in meerdere talen werkt. Automatische vertalingen, iDEAL, PayPal en meer." lang="nl">
  <section class="hero text-white py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 px-3 py-1 bg-white/20 rounded-full text-sm mb-4">
          <Icon name="globe" size={16} class="text-white" /> Feature
        </span>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">
          Verkoop wereldwijd in <span class="text-accent">meerdere talen</span>
        </h1>
        <p class="text-xl text-white/80 mb-8">
          Met ShopVirge wordt je hele webshop automatisch vertaald. 
          Producten, beschrijvingen, pagina's — alles in de talen die jij kiest.
        </p>
        <a href={`${base}nl/contact/`} class="btn-primary bg-white text-brand hover:bg-gray-100">
          Start vandaag →
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Hoe automatisch vertalen werkt</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand text-white rounded-full flex items-center justify-center font-bold shrink-0">1</div>
              <div>
                <h3 class="font-semibold mb-1">Beschrijf je producten één keer</h3>
                <p class="text-gray-600 text-sm">In het Nederlands, Engels of welke taal je maar wilt. Upload foto's, prijzen, voorraad.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand text-white rounded-full flex items-center justify-center font-bold shrink-0">2</div>
              <div>
                <h3 class="font-semibold mb-1">Kies je talen</h3>
                <p class="text-gray-600 text-sm">NL, EN, DE, FR of allemaal. Jij bepaalt welke markten je wilt bereiken.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand text-white rounded-full flex items-center justify-center font-bold shrink-0">3</div>
              <div>
                <h3 class="font-semibold mb-1">ShopVirge vertaalt alles</h3>
                <p class="text-gray-600 text-sm">Titels, beschrijvingen, categorieën — automatisch en accuraat. Je kunt altijd handmatig aanpassen.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-gray-100 rounded-2xl p-8">
          <h3 class="font-bold mb-4">Ondersteunde talen</h3>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-white rounded-lg p-4 text-center shadow-sm">
              <span class="text-2xl">🇳🇱</span>
              <p class="text-sm font-medium mt-1">Nederlands</p>
            </div>
            <div class="bg-white rounded-lg p-4 text-center shadow-sm">
              <span class="text-2xl">🇬🇧</span>
              <p class="text-sm font-medium mt-1">English</p>
            </div>
            <div class="bg-white rounded-lg p-4 text-center shadow-sm">
              <span class="text-2xl">🇩🇪</span>
              <p class="text-sm font-medium mt-1">Deutsch</p>
            </div>
            <div class="bg-white rounded-lg p-4 text-center shadow-sm">
              <span class="text-2xl">🇫🇷</span>
              <p class="text-sm font-medium mt-1">Français</p>
            </div>
            <div class="bg-white rounded-lg p-4 text-center shadow-sm">
              <span class="text-2xl">🇪🇸</span>
              <p class="text-sm font-medium mt-1">Español</p>
            </div>
            <div class="bg-white rounded-lg p-4 text-center shadow-sm">
              <span class="text-2xl">🇮🇹</span>
              <p class="text-sm font-medium mt-1">Italiano</p>
            </div>
          </div>
          <p class="text-sm text-gray-500 mt-4 text-center">Meer talen op aanvraag beschikbaar</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-alt py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">Alles wat je meertalige shop nodig heeft</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="card">
          <div class="w-10 h-10 bg-brand/10 rounded-xl flex items-center justify-center mb-3">
            <Icon name="languages" size={20} class="text-brand" />
          </div>
          <h3 class="font-bold mb-2">Taalschakelaar</h3>
          <p class="text-gray-600 text-sm">Bezoekers switchen met één klik tussen talen. De kleur en positie passen we aan je huisstijl aan.</p>
        </div>
        <div class="card">
          <div class="w-10 h-10 bg-brand/10 rounded-xl flex items-center justify-center mb-3">
            <Icon name="pencil" size={20} class="text-brand" />
          </div>
          <h3 class="font-bold mb-2">Handmatig aanpassen</h3>
          <p class="text-gray-600 text-sm">Niet tevreden met een automatische vertaling? Pas direct aan in de editor. Geen code nodig.</p>
        </div>
        <div class="card">
          <div class="w-10 h-10 bg-brand/10 rounded-xl flex items-center justify-center mb-3">
            <Icon name="coins" size={20} class="text-brand" />
          </div>
          <h3 class="font-bold mb-2">Lokale valuta's</h3>
          <p class="text-gray-600 text-sm">Toon prijzen in euro's, dollars of ponden. Automatisch omgerekend met actuele koersen.</p>
        </div>
        <div class="card">
          <div class="w-10 h-10 bg-brand/10 rounded-xl flex items-center justify-center mb-3">
            <Icon name="search" size={20} class="text-brand" />
          </div>
          <h3 class="font-bold mb-2">SEO per taal</h3>
          <p class="text-gray-600 text-sm">Elke taalversie heeft zijn eigen meta-beschrijvingen en titels voor Google. Meer verkeer, meer klanten.</p>
        </div>
        <div class="card">
          <div class="w-10 h-10 bg-brand/10 rounded-xl flex items-center justify-center mb-3">
            <Icon name="zap" size={20} class="text-brand" />
          </div>
          <h3 class="font-bold mb-2">Snelle laadtijden</h3>
          <p class="text-gray-600 text-sm">Elke pagina laadt snel, ongeacht de taal. Geen vertaalplugins die je site vertragen.</p>
        </div>
        <div class="card">
          <div class="w-10 h-10 bg-brand/10 rounded-xl flex items-center justify-center mb-3">
            <Icon name="shield-check" size={20} class="text-brand" />
          </div>
          <h3 class="font-bold mb-2">Veilige betalingen</h3>
          <p class="text-gray-600 text-sm">iDEAL, PayPal, creditcard — in elke taal werkt het perfect. SSL inbegrepen.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Klaar om wereldwijd te verkopen?</h2>
      <p class="text-lg text-gray-600 mb-8">Start vandaag nog met je meertalige webshop. Binnen een uur sta je live.</p>
      <a href={`${base}nl/contact/`} class="btn-primary">Neem contact op →</a>
    </div>
  </section>
</Layout>
