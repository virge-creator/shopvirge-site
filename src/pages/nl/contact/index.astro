---
import Layout from '../../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Contact — Neem contact op" lang="nl">
  <section class="hero text-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Contact</h1>
        <p class="text-xl text-white/80">
          Klaar om te beginnen? Stuur ons een bericht en we helpen je binnen 24 uur verder.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Stuur een bericht</h2>
          <form action="https://formspree.io/f/mkokrkdl" method="POST" class="space-y-4">
            <input type="hidden" name="_subject" value="Nieuw contactbericht - ShopVirge" />
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Naam</label>
              <input type="text" name="name" required 
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">E-mail</label>
              <input type="email" name="email" required 
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Telefoon</label>
              <input type="tel" name="phone"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Waar ben je naar op zoek?</label>
              <select name="type" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none bg-white">
                <option value="">Kies een optie...</option>
                <option value="webshop">Webshop</option>
                <option value="portfolio">Portfolio site</option>
                <option value="beide">Beide</option>
                <option value="anders">Anders</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Bericht</label>
              <textarea name="message" rows="5" required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none resize-none"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full">Verstuur bericht →</button>
          </form>
        </div>
        <div class="space-y-8">
          <div>
            <h3 class="text-lg font-bold mb-4">Bezoek ons</h3>
            <address class="text-gray-600 not-italic leading-relaxed">
              <strong>ShopVirge</strong><br />
              Julianastraat 63<br />
              6039 AH Stramproy<br />
              Nederland
            </address>
          </div>
          <div class="bg-gray-200 rounded-2xl overflow-hidden h-80">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2486.0!2d5.65!3d51.2!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sJulianastraat+63%2C+6039+AH+Stramproy!5e0!3m2!1snl!2snl!4v1700000000000!5m2!1snl!2snl"
              width="100%" height="100%" style="border:0; filter: grayscale(1);" allowfullscreen="" loading="lazy"
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
