---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Functies — Alles wat je nodig hebt" lang="nl">
  <section class="hero text-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Functies</h1>
        <p class="text-xl text-white/80">
          Alles wat je nodig hebt om een professionele, meertalige webshop of portfolio te lanceren.
        </p>
      </div>
    </div>
  </section>

  <!-- Feature blocks -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-24">

      <!-- Meertalig -->
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-5xl mb-4">🌍</div>
          <h2 class="text-3xl font-bold mb-4">Automatisch meertalig</h2>
          <p class="text-gray-600 mb-4">
            Vertalen was nog nooit zo makkelijk. Jouw hele site — producten, tekst, pagina's — 
            wordt automatisch vertaald in de talen die jij kiest.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Nederlands, Engels, Duits, Frans, Spaans en meer</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> SEO-geoptimaliseerde vertalingen per taal</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Handmatige aanpassingen altijd mogelijk</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Automatische taaldetectie voor bezoekers</li>
          </ul>
        </div>
        <div class="bg-brand/5 rounded-2xl p-12 flex items-center justify-center">
          <div class="text-8xl">🌐</div>
        </div>
      </div>

      <!-- Snel live -->
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="md:order-2">
          <div class="text-5xl mb-4">⚡</div>
          <h2 class="text-3xl font-bold mb-4">Live in één uur</h2>
          <p class="text-gray-600 mb-4">
            Van concept tot volledig live site in minder dan een uur. 
            Geen technische kennis nodig — upload je producten en de rest gaat vanzelf.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Stap-voor-stap begeleiding</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Drag-and-drop product uploads</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Automatische sitemap en SEO</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Publiceer met één klik</li>
          </ul>
        </div>
        <div class="bg-accent/10 rounded-2xl p-12 flex items-center justify-center md:order-1">
          <div class="text-8xl">🚀</div>
        </div>
      </div>

      <!-- Betalingen -->
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-5xl mb-4">💳</div>
          <h2 class="text-3xl font-bold mb-4">Betaalplatforms ingebakken</h2>
          <p class="text-gray-600 mb-4">
            Accepteer betalingen via iDEAL, PayPal, creditcard en meer — 
            allemaal geïntegreerd, zonder extra plugins.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> iDEAL, Bancontact, PayPal</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Creditcard (Visa, Mastercard, Amex)</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Klarna en achteraf betalen</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Automatische facturen en bonnetjes</li>
          </ul>
        </div>
        <div class="bg-brand/5 rounded-2xl p-12 flex items-center justify-center">
          <div class="text-8xl">💰</div>
        </div>
      </div>

      <!-- Mobiel -->
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="md:order-2">
          <div class="text-5xl mb-4">📱</div>
          <h2 class="text-3xl font-bold mb-4">Mobiel-first design</h2>
          <p class="text-gray-600 mb-4">
            Elke site ziet er perfect uit op telefoon, tablet en desktop. 
            Geoptimaliseerd voor snelheid en conversie.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Responsive op elk schermformaat</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Supersnel (&lt; 1s laadtijd)</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Touch-geoptimaliseerde navigatie</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> PWA-ready</li>
          </ul>
        </div>
        <div class="bg-accent/10 rounded-2xl p-12 flex items-center justify-center md:order-1">
          <div class="text-8xl">📲</div>
        </div>
      </div>

      <!-- Design -->
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-5xl mb-4">🎨</div>
          <h2 class="text-3xl font-bold mb-4">Geen design-skills nodig</h2>
          <p class="text-gray-600 mb-4">
            Professioneel ogende websites uit de doos. 
            Kies uit kant-en-klare templates en pas ze aan met je eigen merk-kleuren.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> 20+ professionele templates</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Eigen kleuren, fonts en logo</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Custom CSS mogelijk</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Dark mode ondersteuning</li>
          </ul>
        </div>
        <div class="bg-brand/5 rounded-2xl p-12 flex items-center justify-center">
          <div class="text-8xl">🎭</div>
        </div>
      </div>

      <!-- Analytics -->
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="md:order-2">
          <div class="text-5xl mb-4">📊</div>
          <h2 class="text-3xl font-bold mb-4">Analytics ingebouwd</h2>
          <p class="text-gray-600 mb-4">
            Volg bezoekers, conversies en productprestaties met 
            ingebouwde dashboards. Geen externe tools nodig.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Realtime bezoekersstatistieken</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Conversie-tracking</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> Bestseller- en trendrapportages</li>
            <li class="flex items-start gap-2"><span class="text-brand mt-1">✓</span> GDPR-compliant (geen cookies)</li>
          </ul>
        </div>
        <div class="bg-accent/10 rounded-2xl p-12 flex items-center justify-center md:order-1">
          <div class="text-8xl">📈</div>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="section-alt py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Klaar om te beginnen?</h2>
      <p class="text-gray-600 mb-8">Start vandaag nog met je meertalige webshop of portfolio.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}contact/`} class="btn-primary">Neem contact op →</a>
        <a href={`${base}prijzen/`} class="btn-secondary">Bekijk prijzen</a>
      </div>
    </div>
  </section>
</Layout>
